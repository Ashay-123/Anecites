generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CANDIDATE
  INTERVIEWER
  REVIEWER
  ADMIN
}

enum ParticipantRole {
  CANDIDATE
  INTERVIEWER
}

enum SessionState {
  CREATED
  SCHEDULED
  LOBBY
  ACTIVE
  ENDED
  CANCELLED
}

enum EvidenceKind {
  EDITOR_REPLAY
  SESSION_RECORDING
  SCREEN_RECORDING
  RISK_CLIP
  CODE_OUTPUT
}

enum CodeSubmissionStatus {
  QUEUED
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  INTERNAL_ERROR
}

enum CodeExecutionMode {
  RUN
  SUBMIT
}

enum RiskReviewStatus {
  PENDING_REVIEW
  CONFIRMED
  DISMISSED
  NEEDS_MORE_CONTEXT
}

enum MonitoringEventSource {
  DESKTOP_APP
  DESKTOP_NATIVE
  EDITOR
  MEDIA_WORKER
  SERVER
}

enum MediaAnalysisJobRunStatus {
  PENDING
  PROCESSING
  SUCCEEDED
}

enum SessionRecordingState {
  ACTIVE
  STOP_REQUESTED
  COMPLETED
  FAILED
}

enum RecordingVerificationState {
  PENDING
  VERIFYING
  REVIEWABLE
  INCOMPLETE
  FAILED
}

enum GazeCalibrationState {
  ACTIVE
  COMPLETED
  ABANDONED
}

model User {
  id                    String        @id @default(cuid())
  email                 String        @unique
  displayName           String
  role                  UserRole      @default(CANDIDATE)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  participants          Participant[]
  reviewedRiskSummaries RiskSummary[] @relation("RiskSummaryReviewer")

  @@index([role])
}

model Session {
  id                         String                     @id @default(cuid())
  problemId                  String?
  title                      String
  state                      SessionState               @default(CREATED)
  scheduledAt                DateTime?
  startedAt                  DateTime?
  endedAt                    DateTime?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  participants               Participant[]
  editorDocuments            EditorDocument[]
  editorTelemetryAggregates  EditorTelemetryAggregate[]
  codeSubmissions            CodeSubmission[]
  riskSummaries              RiskSummary[]
  evidenceObjects            EvidenceObject[]
  mediaConsents              MediaConsent[]
  monitoringConsents         MonitoringConsent[]
  monitoringHeartbeats       MonitoringHeartbeat[]
  riskEvents                 RiskEvent[]
  mediaAnalysisJobRuns       MediaAnalysisJobRun[]
  sessionRecordings          SessionRecording[]
  gazeCalibrations           GazeCalibration[]
  problem                    InterviewProblem?          @relation(fields: [problemId], references: [id], onDelete: SetNull)

  @@index([problemId])
  @@index([state])
  @@index([scheduledAt])
}

model Participant {
  id              String           @id @default(cuid())
  sessionId       String
  userId          String
  role            ParticipantRole
  joinedAt        DateTime?
  leftAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  session         Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeSubmissions CodeSubmission[]
  mediaConsents       MediaConsent[]
  monitoringConsents   MonitoringConsent[]
  monitoringHeartbeats MonitoringHeartbeat[]
  riskEvents           RiskEvent[]
  editorTelemetryAggregates EditorTelemetryAggregate[]
  riskSummaries             RiskSummary[]
  gazeCalibrations          GazeCalibration[]

  @@unique([sessionId, userId, role])
  @@index([sessionId])
  @@index([userId])
}

model EvidenceObject {
  id                    String           @id @default(cuid())
  sessionId             String
  kind                  EvidenceKind
  storageBucket         String
  storageKey            String
  contentType           String
  byteSize              BigInt?
  checksumSha256        String?
  durationMs            Int?
  metadata              Json?
  createdAt             DateTime         @default(now())
  session               Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  replayForDocuments    EditorDocument[] @relation("EditorDocumentReplayObject")
  codeSubmissionOutputs CodeSubmission[] @relation("CodeSubmissionOutputEvidence")
  riskSummaries         RiskSummary[]    @relation("RiskSummaryEvidenceObject")
  riskEvents            RiskEvent[]      @relation("RiskEventEvidenceObject")
  mediaAnalysisJobRuns  MediaAnalysisJobRun[]
  sessionRecording      SessionRecording? @relation("SessionRecordingEvidence")

  @@unique([storageBucket, storageKey])
  @@index([sessionId, kind])
}

model MediaAnalysisJobRun {
  jobId                     String                    @id
  payloadSha256             String
  sessionId                 String
  recordingEvidenceObjectId String
  status                    MediaAnalysisJobRunStatus @default(PENDING)
  leaseVersion              Int                       @default(0)
  lockedAt                  DateTime?
  completedAt               DateTime?
  riskSummaryId             String?                   @unique
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  session                   Session                   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recordingEvidenceObject   EvidenceObject            @relation(fields: [recordingEvidenceObjectId], references: [id], onDelete: Cascade)
  riskSummary               RiskSummary?              @relation(fields: [riskSummaryId], references: [id], onDelete: SetNull)

  @@index([status, lockedAt])
  @@index([sessionId, createdAt])
  @@index([recordingEvidenceObjectId])
}

model SessionRecording {
  id               String                @id @default(cuid())
  sessionId        String
  egressId         String                @unique
  evidenceObjectId String                @unique
  state            SessionRecordingState @default(ACTIVE)
  verificationState RecordingVerificationState @default(PENDING)
  startedAt        DateTime
  stopRequestedAt  DateTime?
  completedAt      DateTime?
  failureCode      String?
  verificationStartedAt DateTime?
  verificationCompletedAt DateTime?
  expectedDurationMs Int?
  recordedDurationMs Int?
  verificationFailureCode String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  session          Session               @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  evidenceObject   EvidenceObject        @relation("SessionRecordingEvidence", fields: [evidenceObjectId], references: [id], onDelete: Cascade)
  gazeCalibrations GazeCalibration[]

  @@index([sessionId, state, createdAt])
}

model MediaConsent {
  id                String      @id @default(cuid())
  sessionId         String
  participantId     String
  noticeVersion     String
  noticeFingerprint String
  scopes            Json
  grantedAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  session           Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant       Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([sessionId, participantId, grantedAt])
  @@index([participantId])
}

model GazeCalibration {
  id                 String               @id @default(cuid())
  sessionId          String
  participantId      String
  sessionRecordingId String?
  state              GazeCalibrationState @default(ACTIVE)
  steps              Json
  startedAt          DateTime             @default(now())
  completedAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  session            Session              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant        Participant          @relation(fields: [participantId], references: [id], onDelete: Cascade)
  sessionRecording   SessionRecording?    @relation(fields: [sessionRecordingId], references: [id], onDelete: Cascade)

  @@index([sessionId, participantId, state, createdAt])
  @@index([participantId, createdAt])
  @@index([sessionRecordingId, createdAt])
}

model MonitoringConsent {
  id                     String                @id @default(cuid())
  sessionId              String
  participantId          String
  policyVersion          String
  policyDigestSha256     String?
  nativeMonitoringPolicy Json?
  scopes                 Json
  clientInstanceId       String
  clientVersion          String
  grantedAt              DateTime
  revokedAt              DateTime?
  monitoringStartedAt    DateTime
  monitoringStoppedAt    DateTime?
  stopReason             String?
  lastSequence           Int                   @default(0)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  session                Session               @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant         Participant           @relation(fields: [participantId], references: [id], onDelete: Cascade)
  heartbeats          MonitoringHeartbeat[]
  riskEvents          RiskEvent[]

  @@index([sessionId, participantId, monitoringStartedAt])
  @@index([sessionId, monitoringStartedAt])
  @@index([participantId])
}

model MonitoringHeartbeat {
  id                  String            @id @default(cuid())
  monitoringConsentId String
  sessionId           String
  participantId       String
  sequence            Int
  occurredAt          DateTime
  createdAt           DateTime          @default(now())
  monitoringConsent   MonitoringConsent @relation(fields: [monitoringConsentId], references: [id], onDelete: Cascade)
  session             Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant         Participant       @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([monitoringConsentId, sequence])
  @@index([sessionId, occurredAt])
  @@index([participantId, occurredAt])
}

model RiskEvent {
  id                  String                 @id @default(cuid())
  monitoringConsentId String?
  sessionId           String
  participantId       String?
  evidenceObjectId    String?
  sequence            Int?
  type                String
  source              MonitoringEventSource
  confidence          Decimal                @db.Decimal(5, 4)
  detectorVersion     String
  occurredAt          DateTime
  metadata            Json?
  createdAt           DateTime               @default(now())
  monitoringConsent   MonitoringConsent?     @relation(fields: [monitoringConsentId], references: [id], onDelete: SetNull)
  session             Session                @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant         Participant?           @relation(fields: [participantId], references: [id], onDelete: SetNull)
  evidenceObject      EvidenceObject?        @relation("RiskEventEvidenceObject", fields: [evidenceObjectId], references: [id], onDelete: SetNull)

  @@unique([monitoringConsentId, sequence])
  @@index([sessionId, occurredAt])
  @@index([participantId, occurredAt])
  @@index([type])
  @@index([evidenceObjectId])
}

model EditorDocument {
  id                         String                     @id @default(cuid())
  sessionId                  String
  language                   String
  initialContent             String                     @default("") @db.Text
  finalContent               String?                    @db.Text
  replayObjectId             String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  session                    Session                    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  replayObject               EvidenceObject?            @relation("EditorDocumentReplayObject", fields: [replayObjectId], references: [id], onDelete: SetNull)
  telemetryAggregates        EditorTelemetryAggregate[]
  codeSubmissions            CodeSubmission[]

  @@index([sessionId])
  @@index([replayObjectId])
}

model EditorTelemetryAggregate {
  id                String         @id @default(cuid())
  sessionId         String
  participantId     String?
  documentId        String
  windowStartedAt   DateTime
  windowEndedAt     DateTime
  insertEventCount  Int            @default(0)
  deleteEventCount  Int            @default(0)
  pasteBlockedCount Int            @default(0)
  atomicInsertCount Int            @default(0)
  maxInsertSize     Int            @default(0)
  createdAt         DateTime       @default(now())
  session           Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant       Participant?   @relation(fields: [participantId], references: [id], onDelete: SetNull)
  document          EditorDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([participantId, documentId, windowStartedAt, windowEndedAt])
  @@index([sessionId, windowStartedAt])
  @@index([participantId, windowStartedAt])
}

model InterviewProblem {
  id              String                     @id @default(cuid())
  slug            String                     @unique
  title           String
  difficulty      String
  prompt          String                     @db.Text
  starterCode     String                     @db.Text
  functionName    String
  languageId      Int
  examples        Json
  constraints     Json
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  sessions        Session[]
  testcases       InterviewProblemTestcase[]
  codeSubmissions CodeSubmission[]

  @@index([languageId])
}

model InterviewProblemTestcase {
  id        String           @id @default(cuid())
  problemId String
  ordinal   Int
  input     Json
  expected  Json
  hidden    Boolean          @default(false)
  createdAt DateTime         @default(now())
  problem   InterviewProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, ordinal])
  @@index([problemId])
}

model CodeSubmission {
  id                     String               @id @default(cuid())
  sessionId              String
  problemId              String?
  participantId          String?
  documentId             String
  languageId             Int
  executionMode          CodeExecutionMode     @default(RUN)
  sourceHashSha256       String
  stdin                  String?              @db.Text
  stdout                 String?              @db.Text
  stderr                 String?              @db.Text
  status                 CodeSubmissionStatus @default(QUEUED)
  judge0Token            String?
  timeMs                 Int?
  memoryKb               Int?
  outputEvidenceObjectId String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  session                Session              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  problem                InterviewProblem?    @relation(fields: [problemId], references: [id], onDelete: SetNull)
  participant            Participant?         @relation(fields: [participantId], references: [id], onDelete: SetNull)
  document               EditorDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  outputEvidence         EvidenceObject?      @relation("CodeSubmissionOutputEvidence", fields: [outputEvidenceObjectId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([problemId])
  @@index([participantId])
  @@index([documentId])
  @@index([outputEvidenceObjectId])
}

model RiskSummary {
  id                    String           @id @default(cuid())
  sessionId             String
  participantId         String?
  correlationKey        String?          @unique
  evidenceObjectId      String?
  windowStartedAt       DateTime
  windowEndedAt         DateTime
  score                 Decimal          @db.Decimal(5, 4)
  correlatedSignalCount Int
  meetsCorrelationPolicy Boolean         @default(false)
  humanReviewRequired   Boolean          @default(true)
  reviewStatus          RiskReviewStatus @default(PENDING_REVIEW)
  reviewerId            String?
  reviewedAt            DateTime?
  rationale             String?          @db.Text
  signalBreakdown       Json
  evidenceReferences    Json             @default("[]")
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  session               Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant           Participant?     @relation(fields: [participantId], references: [id], onDelete: SetNull)
  evidenceObject        EvidenceObject?  @relation("RiskSummaryEvidenceObject", fields: [evidenceObjectId], references: [id], onDelete: SetNull)
  reviewer              User?            @relation("RiskSummaryReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  mediaAnalysisJobRun   MediaAnalysisJobRun?

  @@index([sessionId, windowStartedAt])
  @@index([sessionId, participantId, windowStartedAt])
  @@index([reviewStatus])
  @@index([evidenceObjectId])
  @@index([reviewerId])
}
