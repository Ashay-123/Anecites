{
  "name": "@anecites/editor-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:deps": "npm run build --workspace @anecites/shared && npm run build --workspace @anecites/collab",
    "build": "npm run build:deps && tsc -p tsconfig.json",
    "typecheck": "npm run build:deps && tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck",
    "test": "npm run build && node --test --test-isolation=none test/*.test.mjs"
  },
  "dependencies": {
    "@anecites/shared": "0.0.0",
    "monaco-editor": "^0.53.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "y-protocols": "^1.0.7",
    "yjs": "13.6.31"
  },
  "devDependencies": {
    "@anecites/collab": "0.0.0",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jose": "6.2.3",
    "ws": "8.21.0"
  }
}
