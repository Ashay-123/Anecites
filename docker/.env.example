POSTGRES_DB=anecites
POSTGRES_USER=anecites
POSTGRES_PASSWORD=anecites_dev_password
POSTGRES_PORT=5432

REDIS_PORT=6379

RABBITMQ_USER=anecites
RABBITMQ_PASSWORD=anecites_dev_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
MEDIA_ANALYSIS_QUEUE_NAME=media-analysis.jobs
MEDIA_ANALYSIS_CONSUMER_PREFETCH=1
MEDIA_ANALYSIS_MAX_RETRIES=3
MEDIA_ANALYSIS_RETRY_DELAY_MS=5000
MEDIA_ANALYSIS_JOB_LEASE_MS=600000
MEDIA_ANALYSIS_SHADOW_QUEUE_NAME=media-analysis.shadow.v1.jobs

MINIO_ROOT_USER=anecites
MINIO_ROOT_PASSWORD=anecites_dev_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MEDIA_INFERENCE_AUTH_TOKEN=local_media_inference_dev_token_change_me
MEDIA_INFERENCE_EXPECTED_ADAPTER_VERSION=mediapipe-face-landmarker-0.10.35_silero-vad-6.2.1_pyannote-audio-4.0.7
MEDIA_INFERENCE_ALLOWED_BUCKETS=anecites-dev
MEDIA_INFERENCE_MAX_MEDIA_BYTES=536870912
MEDIA_INFERENCE_PROCESSING_TIMEOUT_SECONDS=240
MEDIA_INFERENCE_FACE_MIN_DETECTION_CONFIDENCE=0.5
MEDIA_INFERENCE_VIDEO_FRAMES_PER_WINDOW=5
MEDIA_INFERENCE_VAD_THRESHOLD=0.5
MEDIA_INFERENCE_VAD_MIN_SPEECH_MS=250
# Disabled until the gated model has been accepted, downloaded, benchmarked, and approved.
MEDIA_INFERENCE_SPEAKER_DIARIZATION_ENABLED=false
MEDIA_INFERENCE_SPEAKER_DIARIZATION_MODEL_PATH=/models/pyannote/speaker-diarization-community-1
# Required only for `docker compose --profile media-model-bootstrap run --rm media-model-bootstrap`.
# Do not put the token in source control or the running media-inference service environment.
HF_TOKEN=
# Pin this to the 40-character model commit selected during model review. The enabled runtime verifies it.
MEDIA_INFERENCE_SPEAKER_DIARIZATION_MODEL_REVISION=

PISTON_IMAGE=ghcr.io/engineer-man/piston
PISTON_PORT=2000

LIVEKIT_IMAGE=livekit/livekit-server:latest
LIVEKIT_EGRESS_IMAGE=livekit/egress:latest
LIVEKIT_HTTP_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881
LIVEKIT_RTC_UDP_PORT=7882

JUDGE0_IMAGE=judge0/judge0:latest
JUDGE0_PORT=2358
