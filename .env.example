NODE_ENV=development

API_HOST=127.0.0.1
API_PORT=3000
APP_ORIGIN=http://127.0.0.1:5173
API_ORIGIN=http://127.0.0.1:3000
LOCAL_DEMO_ENABLED=true
# Set automatically by the public-demo launcher. Keep empty for normal local development.
LOCAL_DEMO_PUBLIC_BASE_URL=
COLLAB_HOST=127.0.0.1
COLLAB_PORT=3001
COLLAB_ORIGIN=ws://localhost:3001
COLLAB_TELEMETRY_RAW_STREAM_KEY=anecites:editor:raw
JSON_BODY_LIMIT=1mb
AUTH_JWT_SECRET=local_dev_auth_secret_change_me_minimum_32_characters

DATABASE_URL=postgresql://anecites:anecites_dev_password@localhost:5432/anecites
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://anecites:anecites_dev_password@localhost:5672
# Host-side services reach the local object store through the published port.
S3_ENDPOINT=http://localhost:9000
# LiveKit Egress runs inside Docker, so this endpoint must resolve from that network.
LIVEKIT_RECORDING_S3_ENDPOINT=http://minio:9000
S3_BUCKET=anecites-dev
S3_ACCESS_KEY_ID=anecites
S3_SECRET_ACCESS_KEY=anecites_dev_password
S3_REGION=us-east-1
COLLAB_REPLAY_EVIDENCE_KEY_PREFIX=replay/editor
# Generic S3-compatible recording and playback settings. Do not make the bucket public.
RECORDING_STORAGE_KEY_PREFIX=recordings/livekit
EVIDENCE_SIGNED_URL_TTL_SECONDS=900
RECORDING_VERIFICATION_QUEUE_NAME=recording-verification.jobs
RECORDING_COMPLETENESS_ABSOLUTE_TOLERANCE_MS=5000
RECORDING_COMPLETENESS_RELATIVE_TOLERANCE_PERCENT=2
RECORDING_VERIFICATION_TIMEOUT_MS=30000

# --- Data Retention Policy Knobs ---

# These values document policy and should be enforced by a separate cleanup worker before production use.
EVIDENCE_RETENTION_DAYS=90
RECORDING_RETENTION_DAYS=30
REPLAY_RETENTION_DAYS=90
TELEMETRY_RETENTION_DAYS=180
RISK_SUMMARY_RETENTION_DAYS=365

# --- Native Monitoring Policy ---

# JSON array of exact process basenames and case-insensitive visible-window title fragments.
# Keep empty until each rule has been verified against a controlled test fixture.
MONITORING_POLICY_VERSION=2026-07-17.1
MONITORING_PROHIBITED_APPLICATION_RULES_JSON=[]

# Production-only integrity keys. Keep the private PKCS#8 key backend-only.
# A production desktop build must pin the matching Ed25519 public key.
MONITORING_POLICY_SIGNING_KEY_ID=
MONITORING_POLICY_SIGNING_PRIVATE_KEY_PKCS8_BASE64=

# Public verification keys intentionally embedded in signed desktop builds.
# Example: {"monitoring-policy-2026-01":"<SPKI DER base64>"}
VITE_MONITORING_POLICY_PUBLIC_KEYS_JSON={}

# --- Code Execution ---

# Provider: "piston" for local development, or "judge0" for optional future self-hosted Linux use.
CODE_EXECUTION_PROVIDER=piston
CODE_EXECUTION_ALLOWED_LANGUAGE_IDS=63,71

PISTON_BASE_URL=http://127.0.0.1:2000
PISTON_REQUEST_TIMEOUT_MS=15000

# Optional future self-hosted Judge0 alternative:
# JUDGE0_BASE_URL=http://localhost:2358
# JUDGE0_AUTHN_HEADER=X-Judge0-Token
# JUDGE0_AUTHN_TOKEN=
# JUDGE0_REQUEST_TIMEOUT_MS=15000

CODE_EXECUTION_CPU_TIME_LIMIT_SECONDS=2
CODE_EXECUTION_WALL_TIME_LIMIT_SECONDS=5
CODE_EXECUTION_MEMORY_LIMIT_KB=131072
CODE_EXECUTION_STACK_LIMIT_KB=64000
CODE_EXECUTION_SOURCE_LIMIT_BYTES=65536
CODE_EXECUTION_STDIN_LIMIT_BYTES=8192
CODE_EXECUTION_OUTPUT_LIMIT_BYTES=65536

# --- Video (LiveKit) ---

# Backend-only LiveKit token signing. Do not expose the key or secret to Vite/Tauri.
# The free public demo requires a remote wss:// LiveKit URL and matching backend-only credentials.
# Keep the loopback values below for normal self-hosted local development.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_URL=http://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_livekit_local_minimum_32_chars
LIVEKIT_TOKEN_TTL_SECONDS=3600
# Backward-compatible alias. Prefer RECORDING_STORAGE_KEY_PREFIX above.
LIVEKIT_RECORDING_KEY_PREFIX=recordings/livekit
# When true, only an active interviewer can transition a consented session into recording.
# Leave disabled until the candidate consent UI and operational recording review are complete.
LIVEKIT_RECORDING_AUTO_LIFECYCLE_ENABLED=false
# Configure LiveKit to POST signed events to the backend-only endpoint:
# https://<api-host>/webhooks/livekit
S3_FORCE_PATH_STYLE=true

# --- Server-side Media Analysis ---

# Disabled by default so normal API development does not require the media worker.
MEDIA_ANALYSIS_ENABLED=false
# Record the exact counsel-approved candidate notice version before enabling this in production.
# Production must also set the exact counsel-approved notice text. The server fingerprints it so
# a changed notice requires a fresh consent even if an operator accidentally keeps the same version.
MEDIA_CONSENT_NOTICE_VERSION=development-v1
MEDIA_CONSENT_NOTICE_TEXT=Development-only notice: recording and optional media analysis are for local testing only and are not a production consent notice.
MEDIA_ANALYSIS_QUEUE_NAME=media-analysis.jobs
MEDIA_ANALYSIS_CONSUMER_PREFETCH=1
MEDIA_ANALYSIS_MAX_RETRIES=3
MEDIA_ANALYSIS_RETRY_DELAY_MS=5000
MEDIA_ANALYSIS_JOB_LEASE_MS=600000
MEDIA_ANALYSIS_SAMPLE_WINDOW_MS=10000
MEDIA_ANALYSIS_MAX_SAMPLES_PER_RECORDING=12
MEDIA_ANALYSIS_REQUEST_TIMEOUT_MS=30000
# `shadow` executes second-voice analysis without creating reviewer signals. `review` is not implemented.
MEDIA_ANALYSIS_SECOND_VOICE_MODE=disabled
# `shadow` only enables explicit camera-calibration consent and a candidate calibration flow.
# Gaze inference and reviewer signals remain unavailable.
MEDIA_ANALYSIS_GAZE_MODE=disabled
# Shadow analysis uses a separate queue so older workers cannot persist shadow observations as risk signals.
MEDIA_ANALYSIS_SHADOW_QUEUE_NAME=media-analysis.shadow.v1.jobs
MEDIA_ANALYSIS_SECOND_VOICE_CONFIDENCE_THRESHOLD=0.8
MEDIA_ANALYSIS_FACE_MISSING_CONFIDENCE_THRESHOLD=0.8
MEDIA_ANALYSIS_MULTIPLE_FACES_CONFIDENCE_THRESHOLD=0.8
MEDIA_ANALYSIS_GAZE_OFFSCREEN_CONFIDENCE_THRESHOLD=0.85

# Internal model runtime. These variables remain backend/worker-only and must never use VITE_ prefixes.
# Resolved from the future containerized media-worker on the private Compose network.
MEDIA_INFERENCE_BASE_URL=http://media-inference:8080
MEDIA_INFERENCE_AUTH_TOKEN=local_media_inference_dev_token_change_me
MEDIA_INFERENCE_EXPECTED_ADAPTER_VERSION=mediapipe-face-landmarker-0.10.35_silero-vad-6.2.1_pyannote-audio-4.0.7
MEDIA_INFERENCE_ALLOWED_BUCKETS=anecites-dev
MEDIA_INFERENCE_MAX_MEDIA_BYTES=536870912
MEDIA_INFERENCE_PROCESSING_TIMEOUT_SECONDS=240
MEDIA_INFERENCE_FACE_MIN_DETECTION_CONFIDENCE=0.5
MEDIA_INFERENCE_VIDEO_FRAMES_PER_WINDOW=5
MEDIA_INFERENCE_VAD_THRESHOLD=0.5
MEDIA_INFERENCE_VAD_MIN_SPEECH_MS=250
# Disabled until the gated diarization model is accepted, downloaded, benchmarked, and approved.
MEDIA_INFERENCE_SPEAKER_DIARIZATION_ENABLED=false
MEDIA_INFERENCE_SPEAKER_DIARIZATION_MODEL_PATH=/models/pyannote/speaker-diarization-community-1
# Required by both the one-shot bootstrap profile and the enabled offline runtime. Never expose this to desktop clients.
HF_TOKEN=
# Pin this to the reviewed 40-character Hugging Face model commit before bootstrapping.
MEDIA_INFERENCE_SPEAKER_DIARIZATION_MODEL_REVISION=
