{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anecites",
  "version": "0.0.0",
  "identifier": "com.anecites.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist-web"
  },
  "app": {
    "windows": [
      {
        "title": "Anecites Interview",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
