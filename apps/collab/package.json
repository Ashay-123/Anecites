{
  "name": "@anecites/collab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:deps": "npm run build --workspace @anecites/db && npm run build --workspace @anecites/shared",
    "build": "npm run build:deps && tsc -p tsconfig.json",
    "typecheck": "npm run build:deps && tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck",
    "test": "npm run build && node --test --test-isolation=none test/*.test.mjs",
    "dev": "node dist/index.js"
  },
  "dependencies": {
    "@anecites/db": "0.0.0",
    "@anecites/shared": "0.0.0",
    "@aws-sdk/client-s3": "^3.1084.0",
    "jose": "6.2.3",
    "redis": "^6.1.0",
    "ws": "8.21.0",
    "yjs": "13.6.31"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "@types/ws": "8.18.1"
  }
}
